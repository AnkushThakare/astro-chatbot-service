APP_NAME=astro-chatbot-service
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true
APP_HOST=0.0.0.0
APP_PORT=8010
DATABASE_URL=sqlite:///./astro_chatbot.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./astro_chatbot.db
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FORMAT_TYPE=auto

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
JWT_SECRET_KEY=development-insecure-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=

ASTROLOGY_ENGINE_MODE=remote
ASTROLOGY_SERVICE_URL=http://localhost:8000/api/v1
ASTROLOGY_ENGINE_PATH=../astrology-service/src

MEMORY_WINDOW_SIZE=8
RAG_TOP_K=3
DEFAULT_SYSTEM_PROMPT=You are an astrology assistant. Give direct, careful answers. Use retrieved knowledge and chart context when available, and say when information is uncertain.
