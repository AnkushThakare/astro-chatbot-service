APP_NAME=astro-chatbot-service
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true
APP_HOST=0.0.0.0
APP_PORT=8010
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astro_chatbot
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/astro_chatbot
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FORMAT_TYPE=auto

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30
CORE_SERVICE_BASE_URL=https://your-dev-core-service.example.com/api/v1
CORE_SERVICE_TIMEOUT_SECONDS=20
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
JWT_SECRET_KEY=development-insecure-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=

ASTROLOGY_ENGINE_MODE=remote
ASTROLOGY_SERVICE_URL=http://localhost:8000/api/v1
ASTROLOGY_ENGINE_PATH=../astrology-service/src

MEMORY_WINDOW_SIZE=8
RAG_TOP_K=3
RAG_VECTOR_BACKEND=pgvector
RAG_EMBEDDING_PROVIDER=local_hash
RAG_EMBEDDING_MODEL=local-hash-v1
RAG_EMBEDDING_DIMENSIONS=128
RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_TIMEOUT_SECONDS=30
RAG_TEXT_SEARCH_CONFIG=simple
RAG_RERANKER_PROVIDER=heuristic
RAG_RERANKER_MODEL=heuristic-v1
RAG_RERANKER_BASE_URL=https://api.groq.com/openai/v1
RAG_RERANKER_API_KEY=
RAG_RERANKER_TIMEOUT_SECONDS=20
SOFT_PRODUCT_RECOMMENDATIONS_ENABLED=true
DEFAULT_SYSTEM_PROMPT=You are an astrology assistant. Give direct, careful answers. Use retrieved knowledge and chart context when available, and say when information is uncertain.
